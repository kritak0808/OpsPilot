# ============================================================
# OpsPilot AI — Backend Environment Configuration
# Copy this file to .env and fill in values for your environment
# ============================================================

# ─── Application ─────────────────────────────────────────
PROJECT_NAME=OpsPilot AI
API_VERSION=v1
ENV=development
DEBUG=true

# ─── PostgreSQL ───────────────────────────────────────────
# Local development (direct): use localhost
# Docker Compose: use the service name "postgres"
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/opspilot

# ─── Redis ────────────────────────────────────────────────
# Local development (direct): use localhost
# Docker Compose: use the service name "redis"
REDIS_URL=redis://localhost:6379/0

# ─── Telemetry ────────────────────────────────────────────
OTEL_SERVICE_NAME=opspilot-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ─── JWT Security ─────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=opspilot-dev-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── AI Service ──────────────────────────────────────────
AI_ORCHESTRATOR_URL=http://localhost:8001
